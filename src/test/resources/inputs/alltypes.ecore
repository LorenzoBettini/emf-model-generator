    <eStructuralFeatures xsi:type="ecore:EAttribute" name="multiBytePrim" upperBound="-1" eType="#//byte"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="multiCharPrim" upperBound="-1" eType="#//char"/>
    <!-- Unknown type attribute to test default value path -->
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="unknownAttr" eType="#//UnknownType"/>
  </eClassifiers>
</ecore:EPackage>
