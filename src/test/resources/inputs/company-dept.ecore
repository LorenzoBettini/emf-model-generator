<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="company" nsURI="http://www.example.org/company" nsPrefix="co">
  <eClassifiers xsi:type="ecore:EClass" name="Company">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="departments" upperBound="-1"
        eType="ecore:EClass employee-dept.ecore#//Department"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="ceo" eType="ecore:EClass employee-dept.ecore#//Employee"/>
  </eClassifiers>
</ecore:EPackage>
